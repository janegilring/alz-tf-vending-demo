{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contoso.example/schemas/subscription-vending.contract.schema.json",
  "title": "Subscription Vending Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workload_name",
    "environment",
    "owner",
    "cost_center",
    "connectivity_model",
    "subscription",
    "governance",
    "rbac",
    "budget"
  ],
  "properties": {
    "workload_name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 24,
      "pattern": "^[a-z0-9-]+$",
      "description": "Short workload identifier used in names and tags."
    },
    "environment": {
      "type": "string",
      "enum": ["dev", "test", "prod"],
      "description": "Workload environment."
    },
    "owner": {
      "type": "string",
      "minLength": 3,
      "description": "Owner alias, email, or group descriptor used for tagging and budget notifications."
    },
    "cost_center": {
      "type": "string",
      "pattern": "^[A-Z0-9-]{2,20}$",
      "description": "Cost center tag value used for financial reporting."
    },
    "connectivity_model": {
      "type": "string",
      "enum": ["none", "hub_spoke", "vwan"],
      "description": "Connectivity pattern applied at subscription creation."
    },
    "subscription": {
      "type": "object",
      "additionalProperties": false,
      "required": ["billing_scope", "management_group_id", "location"],
      "properties": {
        "billing_scope": {
          "type": "string",
          "pattern": "^/providers/Microsoft\\.Billing/billingAccounts/.+",
          "description": "Billing scope used by subscription alias creation."
        },
        "management_group_id": {
          "type": "string",
          "minLength": 2,
          "description": "Target management group ID for subscription placement."
        },
        "location": {
          "type": "string",
          "minLength": 3,
          "description": "Default Azure location for resources created by the vending module."
        }
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subscription_tags", "policy_assignments"],
      "properties": {
        "subscription_tags": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Additional custom tags merged with the required platform tags."
        },
        "policy_assignments": {
          "type": "array",
          "description": "Policy or initiative assignments to apply at subscription scope during creation.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "policy_definition_id"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 3,
                "maxLength": 64
              },
              "display_name": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "policy_definition_id": {
                "type": "string",
                "pattern": "^/providers/Microsoft\\.Authorization/policy(Definitions|SetDefinitions)/.+"
              },
              "enforcement_mode": {
                "type": "string",
                "enum": ["Default", "DoNotEnforce"],
                "default": "Default"
              },
              "parameters_json": {
                "type": "string",
                "description": "Optional JSON-encoded parameters for the assignment."
              }
            }
          }
        }
      }
    },
    "rbac": {
      "type": "array",
      "description": "Role assignments to apply at subscription creation.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["principal_id", "definition"],
        "properties": {
          "principal_id": {
            "type": "string",
            "pattern": "^[0-9a-fA-F-]{36}$"
          },
          "definition": {
            "type": "string",
            "description": "Role name (for example Contributor) or role definition resource ID."
          },
          "relative_scope": {
            "type": "string",
            "default": ""
          },
          "principal_type": {
            "type": "string",
            "enum": ["User", "Group", "Device", "ForeignGroup", "ServicePrincipal"]
          }
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["amount", "time_grain", "start", "end", "contact_emails"],
      "properties": {
        "amount": {
          "type": "number",
          "minimum": 1
        },
        "time_grain": {
          "type": "string",
          "enum": ["Monthly", "Quarterly", "Annually"]
        },
        "start": {
          "type": "string",
          "format": "date-time"
        },
        "end": {
          "type": "string",
          "format": "date-time"
        },
        "threshold_percent": {
          "type": "number",
          "minimum": 1,
          "maximum": 1000,
          "default": 80
        },
        "contact_emails": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "format": "email"
          }
        }
      }
    },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hub_network_resource_id": {
          "type": "string"
        },
        "vwan_hub_resource_id": {
          "type": "string"
        },
        "spoke_address_space": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/[0-9]{1,2}$"
          }
        },
        "spoke_subnet_prefixes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/[0-9]{1,2}$"
          }
        }
      }
    }
  }
}
