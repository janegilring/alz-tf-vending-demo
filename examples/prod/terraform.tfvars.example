# Required vending inputs
workload_name       = "payments"
environment         = "prod"
owner               = "payments-platform@contoso.com"
cost_center         = "CC-1042"
connectivity_model  = "hub_spoke"

# Subscription creation and placement
location                           = "westeurope"
subscription_billing_scope         = "/providers/Microsoft.Billing/billingAccounts/0000000/enrollmentAccounts/000000"
subscription_management_group_id   = "alz-landingzones-prod"
subscription_workload              = "Production"

# Connectivity options
hub_network_resource_id = "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rg-connectivity/providers/Microsoft.Network/virtualNetworks/vnet-hub-weu"
vwan_hub_resource_id    = null
spoke_address_space     = ["10.140.0.0/24"]
spoke_subnet_prefixes   = ["10.140.0.0/26"]

# RBAC principals
owner_principal_id              = "11111111-1111-1111-1111-111111111111"
platform_ops_group_object_id    = "22222222-2222-2222-2222-222222222222"

# Budget
budget_amount            = 5000
budget_time_grain        = "Monthly"
budget_start_date        = "2026-07-01T00:00:00Z"
budget_end_date          = "2028-12-31T23:59:59Z"
budget_contact_emails    = ["payments-platform@contoso.com", "finops@contoso.com"]
budget_threshold_percent = 80

# Additional tags merged with required tags
additional_subscription_tags = {
  business_unit = "finance"
  data_class    = "confidential"
}

# Policy scope applied at creation (subscription level)
policy_assignments = {
  enforce_allowed_locations = {
    name                 = "pa-allowed-locations"
    policy_definition_id = "/providers/Microsoft.Authorization/policyDefinitions/e56962a6-4747-49cd-b67b-bf8b01975c4c"
    display_name         = "Allowed locations"
    enforcement_mode     = "Default"
    parameters = {
      listOfAllowedLocations = {
        value = ["westeurope", "northeurope"]
      }
    }
  }
}
